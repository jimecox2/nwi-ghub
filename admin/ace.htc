<!-- Table box -->
<script language=javascript>
function IsPosInt(sInput)
	{
	if(sInput=="") return true;//must be empty or number greater than or equal 0
	var sTmp = sInput.toString();
	for(var i=0;i<sTmp.length;i++)
		{
		var sChar = sTmp.charAt(i);
		if(sChar<"0"||sChar>"9") return false;
		}
	return true;
	}
function IsPosIntNotZero(sInput)//must be empty or number greater than or equal 1
	{
	if(sInput=="") return true;
	var sTmp = sInput.toString();
	for(var i=0;i<sTmp.length;i++)
		{
		var sChar = sTmp.charAt(i);
		if(sChar<"0"||sChar>"9") return false;
		}
	if(sInput*1==0) {return false}
	else {return true};
	}

function TableInit()
	{
	//INSERT
	inpRows.unselectable = "off";
	inpCols.unselectable = "off";
	inpTblAlign.unselectable = "off";
	inpWidth.unselectable = "off";
	inpHeight.unselectable = "off";
	inpPadding.unselectable = "off";
	inpSpacing.unselectable = "off";
	inpBorder.unselectable = "off";
	inpBorderColor.unselectable = "off";
	inpBgImage.unselectable = "off";
	inpBgColor.unselectable = "off";

	//EDIT
	//TableInsertRow()
	//TableInsertCol()
	//TableDeleteRow()
	//TableDeleteCol()
	//TableDeleteCell()
	//TableColSpan()
	//TableRowSpan()
	inpTblAlign2.unselectable = "off";
	inpWidth2.unselectable = "off";
	inpHeight2.unselectable = "off";
	inpPadding2.unselectable = "off";
	inpSpacing2.unselectable = "off";
	inpBorder2.unselectable = "off";
	inpBorderColor2.unselectable = "off";
	inpBgImage2.unselectable = "off";
	inpBgColor2.unselectable = "off";

	//CELL
	inpCellWidth.unselectable = "off";
	inpCellHeight.unselectable = "off";
	inpCellAlign.unselectable = "off";
	inpCellVAlign.unselectable = "off";
	inpCellBgImage.unselectable = "off";
	inpCellBgColor.unselectable = "off";
	//inpCellWrap
	}

var oSel_Table //selection state
var sType_Table

function displayTableBox()
	{
	//display table box
	PopupHide()
	
	//set default value
	inpRows.value = 2;
	inpCols.value = 2;
	inpTblAlign.value = "";
	inpWidth.value = "";
	inpHeight.value = "";
	inpPadding.value = 0;
	inpSpacing.value = 0;
	inpBorder.value = 1;
	inpBorderColor.value = "";
	inpBgImage.value = "";
	inpBgColor.value = "";

	
	//get selection
	idContent.focus()
	var oSel	= idContent.document.selection.createRange()
	var sType = idContent.document.selection.type

	//Save selection
	oSel_Table = oSel
	sType_Table = sType
	
	var oBlock = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TABLE") : GetElement(oSel.item(0),"TABLE"))
	if (oBlock!=null) //If inside existing table
		{
		//Get existing table properties
		inpTblAlign2.value = oBlock.align
		
		var st = oBlock.width
		if(st.indexOf("%")!=-1)
			{
			inpWidth2.value = st.substring(0,st.indexOf("%")) //remove last %
			inpWidth2Me.value = "%"
			}
		else
			{
			inpWidth2.value = oBlock.width
			inpWidth2Me.value = ""
			}
			
		var st2 = oBlock.height
		if(st2.indexOf("%")!=-1)
			{
			inpHeight2.value = st2.substring(0,st2.indexOf("%")) //remove last %
			inpHeight2Me.value = "%"
			}
		else
			{
			inpHeight2.value = oBlock.height
			inpHeight2Me.value = ""
			}			
		inpPadding2.value = oBlock.cellPadding
		inpSpacing2.value = oBlock.cellSpacing
		inpBorder2.value = oBlock.border
		
		inpBorderColor2.value = (oBlock.borderColor).substring(1)
		inpBgImage2.value = oBlock.background
		inpBgColor2.value = (oBlock.bgColor).substring(1)

		if(oSel.parentElement != null)//yg dipilih text, bukan control(=table)
			{//Get existing cell properties
			
			var oTD = GetElement(oSel.parentElement(),"TD");
			
			if(oTD==null)return; //jika yg di select adl text tapi meliputi lebih dari satu cell
				
			var st3 = oTD.width //HTML : width
			if(st3.indexOf("%")!=-1)
				{
				inpCellWidth.value = st3.substring(0,st3.indexOf("%")) //remove last %
				inpCellWidthMe.value = "%"
				}
			else
				{
				inpCellWidth.value = oTD.width
				inpCellWidthMe.value = ""
				}
			var st4 = oTD.height //HTML : height
			if(st4.indexOf("%")!=-1)
				{
				inpCellHeight.value = st4.substring(0,st4.indexOf("%")) //remove last %
				inpCellHeightMe.value = "%"
				}
			else
				{
				inpCellHeight.value = oTD.height
				inpCellHeightMe.value = ""
				}			
			
			inpCellAlign.value = oTD.align //HTML : align
			inpCellVAlign.value = oTD.vAlign //HTML : vAlign
			inpCellBgImage.value = oTD.background //HTML : background
			inpCellBgColor.value = (oTD.bgColor).substring(1)	//HTML : bgColor 	
			inpCellWrap.checked = !oTD.noWrap;	
			
			//DISPLAY BOX
			tablebox.style.display='block';
			setPosition();			
			
			//set the tab
			TabEditCell()
			}
		else
			{
			//DISPLAY BOX
			tablebox.style.display='block';
			setPosition();
				
			//set the tab
			TabEditTable()		
			
			//disable create table & edit table
			TabDisable1()
			}
		}
	else
		{
		//DISPLAY BOX
		tablebox.style.display='block';
		setPosition();		
		
		//set the tab
		TabInsertTable()
		
		//disable edit table & edit cell
		TabDisable2()
		}	
	return true;
	}

function TabInsertTable()
	{
	divBorderColorPick.style.display = "none";
	divBgColorPick.style.display = "none";	
		
	idInsertTable.style.display="block";
	idEditTable.style.display="none";
	idEditCell.style.display="none";

	tab1.style.cursor = "";
	tab1.style.background = "#ececec";
	tab1.style.color = "darkslateblue";
	tab1.style.borderBottom = "";
	tab1.innerHTML = "<b>Create Table</b>"

	tab2.style.background = "#bebebe";
	tab2.style.color = "darkslateblue";
	tab2.style.borderBottom = "darkgray 1px solid";
	tab2.innerHTML = "<div style='cursor:hand;width=100%;' onclick='TabEditTable()'><b><u>Edit Table</u></b></div>"
	
	tab3.style.background = "#bebebe";
	tab3.style.color = "darkslateblue";
	tab3.style.borderBottom = "darkgray 1px solid";
	tab3.innerHTML = "<div style='cursor:hand;width=100%;' onclick='TabEditCell()'><b><u>Edit Cell</u></b></div>"
	
	//when the control (table) is selected, the focus shouldn't be displayed. 
	//Then set the focus to another control.
	inpRows.focus();
	}
function TabEditTable()
	{	
	divBorderColor2Pick.style.display = "none";
	divBgColor2Pick.style.display = "none";	
		
	idInsertTable.style.display="none";
	idEditTable.style.display="block";
	idEditCell.style.display="none";

	tab1.style.background = "#bebebe";
	tab1.style.color = "darkslateblue";
	tab1.style.borderBottom = "darkgray 1px solid";
	tab1.innerHTML = "<div style='cursor:hand;width=100%;' onclick='TabInsertTable()'><b><u>Create Table</u></b></div>"

	tab2.style.cursor = "";
	tab2.style.background = "#ececec";
	tab2.style.color = "darkslateblue";
	tab2.style.borderBottom = "";
	tab2.innerHTML = "<b>Edit Table</b>"
	
	tab3.style.background = "#bebebe";
	tab3.style.color = "darkslateblue";
	tab3.style.borderBottom = "darkgray 1px solid";
	tab3.innerHTML = "<div style='cursor:hand;width=100%;' onclick='TabEditCell()'><b><u>Edit Cell</u></b></div>"
	
	//when the control (table) is selected, the focus shouldn't be displayed. 
	//Then set the focus to another control.
	inpBgColor2.focus() 	
	}
function TabEditCell()
	{
	idEditCell.style.display="block";
	divCellBgColorPick.style.display = "none";
		
	idInsertTable.style.display="none";
	idEditTable.style.display="none";
	idEditCell.style.display="block";
	
	tab1.style.background = "#bebebe";
	tab1.style.color = "darkslateblue";
	tab1.style.borderBottom = "darkgray 1px solid";
	tab1.innerHTML = "<div style='cursor:hand;width=100%;' onclick='TabInsertTable()'><b><u>Create Table</u></b></div>"
	
	tab2.style.background = "#bebebe";
	tab2.style.color = "darkslateblue";
	tab2.style.borderBottom = "darkgray 1px solid";
	tab2.innerHTML = "<div style='cursor:hand;width=100%;' onclick='TabEditTable()'><b><u>Edit Table</u></b></div>"
	
	tab3.style.cursor = "";
	tab3.style.background = "#ececec";
	tab3.style.color = "darkslateblue";
	tab3.style.borderBottom = "";
	tab3.innerHTML = "<b>Edit Cell</b>"	
	
	//when the control (table) is selected, the focus shouldn't be displayed. 
	//Then set the focus to another control.
	inpCellBgColor.focus()	
	}
function TabDisable1()
	{
	tab1.style.cursor = "";
