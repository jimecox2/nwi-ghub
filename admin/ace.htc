				{
				//check if it was already written
				if(divBgColorPick.innerHTML=="")
					{
					//if not written yet, then write
					divBgColorPick.innerHTML = writeColorPicker("inpBgColorPick","inpBgColor.value=inpBgColorPick.value",1);
					//set default color
					setDefaultColor("inpBgColorPick",inpBgColor.value)
					}
				else
					{
					//already written
					//set default color
					setDefaultColor("inpBgColorPick",inpBgColor.value)
					}
				//display
				divBgColorPick.style.display="block"
				}
			else
				{
				//hide
				divBgColorPick.style.display='none'
				}
			}
