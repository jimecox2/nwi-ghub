function TabDisable2()
	{
	tab2.style.cursor = "";
	tab2.style.background = "#bebebe";
	tab2.style.color = "darkgray";
	tab2.style.borderBottom = "";
	tab2.innerHTML = "<b><u>Edit Table</u></b>"

	tab3.style.cursor = "";
