function TableInsert()
	{
	if(!(IsPosIntNotZero(inpRows.value) &&
		IsPosIntNotZero(inpCols.value) &&
		IsPosIntNotZero(inpWidth.value) &&
		IsPosIntNotZero(inpHeight.value) &&
		IsPosInt(inpBorder.value) &&
		IsPosInt(inpPadding.value) &&
		IsPosInt(inpSpacing.value))) 
		{
		alert("Invalid input.");
		return false;
		}
			
	var sHTML = ""
		+ "<TABLE "
		+ (((inpBorder.value=="") || (inpBorder.value=="0")) ? "class=\"NOBORDER\"" : "")
		+	(inpTblAlign.value != "" ? "align=\"" + inpTblAlign.value + "\" " : "")		
		+	(inpWidth.value != "" ? "width=\"" + inpWidth.value + inpWidthMe.value + "\" " : "")
		+	(inpHeight.value != "" ? "height=\"" + inpHeight.value + inpHeightMe.value + "\" " : "")		
		+	(inpPadding.value != "" ? "cellPadding=\"" + inpPadding.value + "\" " : "")
		+	(inpSpacing.value != "" ? "cellSpacing=\"" + inpSpacing.value + "\" " : "")
		+	(inpBorder.value != "" ? "border=\"" + inpBorder.value + "\" " : "")
		+	(inpBorderColor.value != "" ? "bordercolor=\"" + inpBorderColor.value + "\" " : "")
		+	(inpBgImage.value != "" ? "background=\"" + inpBgImage.value + "\" " : "")
		+	(inpBgColor.value != "" ? "bgColor=\"" + inpBgColor.value + "\" " : "")
		+ ">"
	for (var i=0; i < inpRows.value; i++) 
		{
		sHTML += "<TR>"
		for (var j=0; j < inpCols.value; j++)
		sHTML += "<TD>&nbsp;</TD>"
		sHTML += "</TR>"
		}
	sHTML += "</TABLE>"
		
	idContent.focus()
	if (sType_Table=="Control")oSel_Table.item(0).outerHTML = sHTML
	else oSel_Table.pasteHTML(sHTML)
	
	return true;
	}
function TableUpdate()
	{
	if(!(IsPosIntNotZero(inpWidth2.value) &&
		IsPosIntNotZero(inpHeight2.value) &&
		IsPosInt(inpPadding2.value) &&
		IsPosInt(inpSpacing2.value) &&
		IsPosInt(inpBorder2.value))) 
		{
		alert("Invalid input.");
		return false;
		}
			
	var oBlock = (oSel_Table.parentElement != null ? GetElement(oSel_Table.parentElement(),"TABLE") : GetElement(oSel_Table.item(0),"TABLE"))
	if (oBlock!=null) 
		{
		oBlock.align = inpTblAlign2.value
		if(inpWidth2.value!="")
			{
			oBlock.style.width=""; //remove style width
			oBlock.width = inpWidth2.value + inpWidth2Me.value;
			}
		else
			{
			oBlock.width = ""
			}
		if(inpHeight2.value!="")
			{
			oBlock.style.height=""; //remove style height
			oBlock.height = inpHeight2.value + inpHeight2Me.value;
			}
		else
			{
			oBlock.height = ""
			}		
		oBlock.cellPadding = inpPadding2.value
		oBlock.cellSpacing = inpSpacing2.value
		oBlock.border = inpBorder2.value
		oBlock.borderColor = inpBorderColor2.value
		oBlock.background = inpBgImage2.value
		oBlock.bgColor = inpBgColor2.value
		}
	oSel_Table.select()
	
	return true;
	}
function CellUpdate()
	{
	if(!(IsPosIntNotZero(inpCellWidth.value) &&
		IsPosIntNotZero(inpCellHeight.value))) 
		{
		alert("Invalid input.");
		return false;
		}
			
	var oTD = (oSel_Table.parentElement != null ? GetElement(oSel_Table.parentElement(),"TD") : GetElement(oSel_Table.item(0),"TD"))
	if (oTD!=null)
		{
		if(inpCellWidth.value!="")
			{
			//oTD.style.width=""; //remove style width => tdk perlu
			oTD.width = inpCellWidth.value + inpCellWidthMe.value;
			}
		else
			{
			oTD.width = ""
			}
		if(inpCellHeight.value!="")
			{
			//oTD.style.height=""; //remove style height => tdk perlu
			oTD.height = inpCellHeight.value + inpCellHeightMe.value;
			}
		else
			{
			oTD.height = ""
			}		
		
		oTD.align = inpCellAlign.value ;
		oTD.vAlign = inpCellVAlign.value;
		oTD.background = inpCellBgImage.value;
		oTD.bgColor = inpCellBgColor.value ;
		oTD.noWrap = !inpCellWrap.checked;
		}
	oSel_Table.select()
	
	return true;
	}
	
function TableInsertRow(type)
	{
	var oSel = oSel_Table
	var oBlock = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TABLE") : GetElement(oSel.item(0),"TABLE"))
	
	var numofrows = oBlock.rows.length; //num of rows
	
	//Dia ada di row mana ?
	var i,iRow;
	var oTR = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TR") : GetElement(oSel.item(0),"TR"))	
	for (i=0;i<numofrows;i++)
		{
		if(oTR==oBlock.rows[i]) iRow=i;
		}	
	
	var numofcols = oBlock.rows[0].cells.length //num of cols
	
	var elRow;
	if(type=="above") elRow = oBlock.insertRow(iRow); //insert above
	if(type=="below") elRow = oBlock.insertRow(iRow+1); //insert below
	
	for (i=0;i<numofcols;i++)
		{
		try
			{
			var elCell = elRow.insertCell()
			elCell.innerHTML = "&nbsp;"
			}
		catch(e)
			{}
		}	
	}
function TableDeleteRow()
	{
	var oSel = oSel_Table
	var oBlock = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TABLE") : GetElement(oSel.item(0),"TABLE"))
	var oTR = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TR") : GetElement(oSel.item(0),"TR"))	

	try
		{
		var iRow;
		for (var i=0;i<oBlock.rows.length;i++) //num of rows
			{
			if(oTR==oBlock.rows[i])oBlock.deleteRow(i);
			}
		}
	catch(e)
		{
		return;
		}
	}
function TableInsertCol(type)
	{
	var oSel = oSel_Table
	var oBlock = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TABLE") : GetElement(oSel.item(0),"TABLE"))

	//Di row yg aktif, dia ada di col mana ?
	var oTD = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TD") : GetElement(oSel.item(0),"TD"))	
	var iCol;
	iCol = oTD.cellIndex; //insert left
	if(type=="right") iCol=iCol+1; //insert right
		
		
	var numofrows = oBlock.rows.length; //num of rows
	for (var i=0;i<numofrows;i++) //num of rows
		{
		try
			{
			var elCell = oBlock.rows[i].insertCell(iCol) 
			elCell.innerHTML = "&nbsp;"
			}
		catch(e)
			{}		
		}	
	}
function TableDeleteCol()
	{
	var oSel = oSel_Table
	var oBlock = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TABLE") : GetElement(oSel.item(0),"TABLE"))
	var oTD = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TD") : GetElement(oSel.item(0),"TD"))	
	try
		{
		//Dia ada di row mana ?
		var iRow;
		var oTR = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TR") : GetElement(oSel.item(0),"TR"))	
		for (var i=0;i<oBlock.rows.length;i++) //num of rows
			{
			if(oTR==oBlock.rows[i]) iRow=i;
			}	
		//Di row yg aktif, dia ada di col mana ?
		var iCol = oTD.cellIndex;
		for (var i=0;i<oBlock.rows.length;i++) //num of rows
			{
			oBlock.rows[i].deleteCell(iCol);
			}
		}
	catch(e)
		{
		return;
		}					
	}
function TableDeleteCell()
	{
	var oSel = oSel_Table
	var oBlock = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TABLE") : GetElement(oSel.item(0),"TABLE"))
	var oTD = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TD") : GetElement(oSel.item(0),"TD"))	
	try
		{
		//Dia ada di row mana ?
		var iRow;
		var oTR = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TR") : GetElement(oSel.item(0),"TR"))	
		for (var i=0;i<oBlock.rows.length;i++) //num of rows
			{
			if(oTR==oBlock.rows[i]) iRow=i;
			}	
		//Di row yg aktif, dia ada di col mana ?
		var iCol = oTD.cellIndex;
		oBlock.rows[iRow].deleteCell(iCol);
		}
	catch(e)
		{
		return;
		}
	}
function TableColSpan()
	{
	var oSel = oSel_Table
	var oTD = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TD") : GetElement(oSel.item(0),"TD"))	
	oTD.colSpan = 2;
	}
function TableRowSpan()
	{
	var oSel = oSel_Table
	var oTD = (oSel.parentElement != null ? GetElement(oSel.parentElement(),"TD") : GetElement(oSel.item(0),"TD"))	
	oTD.rowSpan = 2;
	}
</script>


