				{
				//check if it was already written
				if(divCellBgColorPick.innerHTML=="")
					{
					//if not written yet, then write
					divCellBgColorPick.innerHTML = writeColorPicker("inpCellBgColorPick","inpCellBgColor.value=inpCellBgColorPick.value",1);
					//set default color
