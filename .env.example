# Base URL of your Strapi instance.
# IMPORTANT: bare origin only — do NOT include the /api path and do NOT add a
# trailing slash. The code appends /api/... itself (e.g. /api/auth/local).
#   Correct:   https://be2.timebars.com
#   Wrong:     https://be2.timebars.com/api   (causes /api/api/... 404s)
#   Wrong:     https://be2.timebars.com/      (trailing slash)
# Exposed to the browser via next.config.mjs because the JWT is held in client
# memory and auth calls are made from the client.
STRAPI_URL=https://be2.timebars.com

# Strapi's JWT signing secret. Server-only — used for optional server-side
# signature verification (lib/serverAuth.js + /api/auth/verify). Never exposed
# to the browser. In Strapi this is the value of admin/users-permissions JWT
# secret (config/plugins.js -> users-permissions.config.jwtSecret, usually set
# via the APP_KEYS / JWT_SECRET env vars in your Strapi project).
STRAPI_JWT_SECRET=your-jwt-secret

# Strapi API token with full access. Server-only — used by the dashboard API
# proxy (app/api/dashboard/*) to perform privileged writes (create/update/
# delete/share/preprocess dashboard sources) on the user's behalf after
# server-side RBAC checks. Never exposed to the browser; in Docker it is a
# runtime -e var, never baked into the image.
FULL_ACCESS_ADMIN_TOKEN=your-strapi-admin-api-token
