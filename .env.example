# Base URL of your Strapi instance (no trailing slash).
# Exposed to the browser via next.config.mjs because the JWT is held in client
# memory and auth calls are made from the client.
STRAPI_URL=https://your-strapi-url.com

# Strapi's JWT signing secret. Server-only — used for optional server-side
# signature verification (lib/serverAuth.js + /api/auth/verify). Never exposed
# to the browser. In Strapi this is the value of admin/users-permissions JWT
# secret (config/plugins.js -> users-permissions.config.jwtSecret, usually set
# via the APP_KEYS / JWT_SECRET env vars in your Strapi project).
STRAPI_JWT_SECRET=your-jwt-secret
